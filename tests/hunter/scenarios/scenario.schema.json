{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "workflow",
    "capability_profile",
    "capabilities",
    "prompt",
    "expected"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "workflow": {
      "enum": [
        "onboarding",
        "profiles-and-state",
        "tool-use-and-fallbacks",
        "opportunities",
        "documents",
        "relationships",
        "pipeline-and-interviews",
        "end-to-end"
      ]
    },
    "capability_profile": {
      "enum": ["full", "reduced"]
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "unavailable", "failures"],
      "properties": {
        "available": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "unavailable": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "failures": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["capability", "times", "error"],
            "properties": {
              "capability": {
                "type": "string",
                "minLength": 1
              },
              "times": {
                "type": "integer",
                "minimum": 1
              },
              "error": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "fixtures": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^\\.\\./fixtures/"
      }
    },
    "capability_bindings": {
      "type": "object",
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "pattern": "^\\.\\./fixtures/"
        }
      }
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["must", "must_not", "state"],
      "properties": {
        "must": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "must_not": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "state": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
